# ==============================================
# RAG Techniques - Centralized Environment Configuration
# ==============================================

# OpenAI Configuration
OPENAI_API_KEY=your_openai_api_key_here

# Vector Database Configuration - Choose your vector DB
# Pinecone
PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_ENVIRONMENT=your_pinecone_environment_here
PINECONE_INDEX_NAME=rag-techniques

# Weaviate
WEAVIATE_URL=your_weaviate_url_here
WEAVIATE_API_KEY=your_weaviate_api_key_here

# Qdrant
QDRANT_URL=your_qdrant_url_here
QDRANT_API_KEY=your_qdrant_api_key_here

# Milvus/Zilliz
MILVUS_HOST=your_milvus_host_here
MILVUS_PORT=19530
ZILLIZ_CLOUD_URI=your_zilliz_cloud_uri_here
ZILLIZ_CLOUD_API_KEY=your_zilliz_api_key_here

# ChromaDB
CHROMA_HOST=localhost
CHROMA_PORT=8000

# Additional API Keys
COHERE_API_KEY=your_cohere_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
GROQ_API_KEY=your_groq_api_key_here

# Hugging Face
HUGGINGFACE_API_KEY=your_huggingface_api_key_here

# LangChain
LANGCHAIN_API_KEY=your_langchain_api_key_here
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=rag-techniques

# AWS Bedrock (optional)
AWS_ACCESS_KEY_ID=your_aws_access_key_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_key_here
AWS_REGION=us-east-1

# Model Configuration
DEFAULT_EMBEDDING_MODEL=text-embedding-ada-002
DEFAULT_LLM_MODEL=gpt-4
DEFAULT_TEMPERATURE=0.0

# Vector DB Selection (default)
VECTOR_DB_PROVIDER=pinecone
# Options: pinecone, weaviate, qdrant, milvus, chroma, faiss

# Data Paths
DATA_DIR=../data
IMAGES_DIR=../images
